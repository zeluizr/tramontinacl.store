{
  "header": {
    "blocks": ["header-layout.desktop", "header-layout.mobile"]
  },
  "header.full": {
    "blocks": ["header-layout.desktop", "header-layout.mobile"]
  },
  "header-layout.desktop": {
    "children": ["flex-layout.row#telemarketing", "flex-layout.row#header-desktop"]
  },
  "header-layout.mobile": {
    "children": ["flex-layout.row#telemarketing", "flex-layout.row#header-mobile"]
  }
}
